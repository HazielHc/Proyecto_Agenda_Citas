datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Business {
  id              Int       @id @default(autoincrement()) @map("id_negocio")
  name            String    @map("nombre")
  email           String    @unique @map("correo")
  passwordHash    String    @map("contrasena_hash")
  plan            String    @default("profesional")
  whatsappSession String?   @map("whatsapp_session")
  active          Boolean   @default(true) @map("activo")
  createdAt       DateTime  @default(now()) @map("fecha_registro")

  barbers         Barber[]
  clients         Client[]
  appointments    Appointment[]
  waitlistEntries WaitlistEntry[]
  chatSessions    ChatSession[]

  @@map("negocios")
}

model Barber {
  id           Int      @id @default(autoincrement()) @map("id_barbero")
  businessId   Int      @map("id_negocio")
  firstName    String   @map("nombre")
  lastName     String   @map("apellido")
  role         String   @default("barbero")
  email        String
  passwordHash String   @map("contrasena_hash")
  active       Boolean  @default(true) @map("activo")

  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([businessId, email])
  @@map("barberos")
}

model Client {
  id        Int      @id @default(autoincrement()) @map("id_cliente")
  businessId Int     @map("id_negocio")
  firstName String   @map("nombre")
  lastName  String   @map("apellido")
  phone     String   @map("telefono")
  createdAt DateTime @default(now()) @map("fecha_registro")

  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  waitlistEntries WaitlistEntry[]

  @@unique([businessId, phone])
  @@map("clientes")
}

model Appointment {
  id          Int       @id @default(autoincrement()) @map("id_cita")
  businessId  Int       @map("id_negocio")
  clientId    Int       @map("id_cliente")
  barberId    Int?      @map("id_barbero")
  service     String    @map("servicio")
  scheduledAt DateTime  @map("fecha_hora")
  durationMin Int       @map("duracion_min")
  status      String    @default("agendada") @map("estado")
  channel     String    @default("web") @map("canal_origen")
  arrivedAt   DateTime? @map("hora_llegada")
  startedAt   DateTime? @map("hora_inicio")
  finishedAt  DateTime? @map("hora_fin")
  pricePaid   Decimal?  @map("precio_pagado")
  createdAt   DateTime  @default(now()) @map("fecha_creacion")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  barber   Barber?  @relation(fields: [barberId], references: [id], onDelete: SetNull)

  @@index([businessId, scheduledAt])
  @@index([businessId, status])
  @@map("citas")
}

model WaitlistEntry {
  id                 Int      @id @default(autoincrement()) @map("id_espera")
  businessId         Int      @map("id_negocio")
  clientId           Int      @map("id_cliente")
  desiredScheduledAt DateTime @map("fecha_hora_deseada")
  service            String   @map("servicio")
  notified           Boolean  @default(false) @map("notificado")
  createdAt          DateTime @default(now()) @map("fecha_registro")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([businessId, desiredScheduledAt])
  @@map("lista_espera")
}

model ChatSession {
  id         Int      @id @default(autoincrement()) @map("id_sesion")
  phone      String   @unique @map("telefono")
  history    String   @map("historial_conversacion")
  updatedAt  DateTime @updatedAt @map("ultima_actualizacion")
  businessId Int      @map("id_negocio")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("sesiones_chat")
}
